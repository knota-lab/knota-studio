{
  "name": "knota-studio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "rsbuild dev --open",
    "build": "rsbuild build",
    "preview": "rsbuild preview",
    "check": "biome check . && tsc --noEmit",
    "lint:fix": "biome check --write . && tsc --noEmit",
    "format": "biome format --write .",
    "prepare": "simple-git-hooks",
    "i18n:extract": "node scripts/extract-i18n.mjs",
    "i18n:extract:dry": "node scripts/extract-i18n.mjs --dry-run",
    "i18n:fix-conflicts": "node scripts/fix-i18n-conflicts.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "preinstall": "node -e \"if(process.env.npm_config_user_agent && !process.env.npm_config_user_agent.includes('pnpm')){console.error('请使用 pnpm 安装依赖：pnpm install');process.exit(1)}\""
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm check"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.108",
    "@iconify/react": "^6.0.2",
    "@tanstack/react-form": "^1.32.0",
    "@tanstack/react-table": "^8.21.3",
    "ahooks": "^3.9.7",
    "chrono-node": "^2.9.1",
    "class-variance-authority": "^0.7.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.2.1",
    "dayjs": "^1.11.20",
    "hash-wasm": "^4.12.0",
    "js-yaml": "^4.1.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.15.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@iconify/types": "^2.0.0",
    "@inquirer/prompts": "^8.4.3",
    "@rsbuild/core": "^2.0.5",
    "@rsbuild/plugin-react": "^2.0.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "clsx": "^2.1.1",
    "shadcn": "^4.7.0",
    "simple-git-hooks": "^2.13.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
